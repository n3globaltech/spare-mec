# Service Book public storefront API base (versioned) + this store's public slug.
# The catalog/order/tracking calls hit:  ${NEXT_PUBLIC_API_URL}/public/${NEXT_PUBLIC_STORE_SLUG}/...
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_STORE_SLUG=sparemec

# Storefront WhatsApp number (digits only, for wa.me links). Falls back to siteConfig.
NEXT_PUBLIC_WHATSAPP_NUMBER=971507855298

# Canonical public site URL — drives sitemap.xml, robots.txt, canonicals, and JSON-LD absolute URLs.
NEXT_PUBLIC_SITE_URL=https://sparemec.ae

# --- Production-only (optional; features stay off until sets) ---
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Analytics only loads when set.
NEXT_PUBLIC_GA_ID=
# Google Search Console verification token (the content="" value of the meta tag).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Exact media/CDN host for product images (e.g. cdn.sparemec.ae) — narrows next/image allow-list.
NEXT_PUBLIC_MEDIA_HOST=
